// Schema do sistema CONTROL - substitui a planilha Google Sheets.
// Entidades base (cadastro), lançamentos manuais e o Lead como
// registro central do funil comercial (preenchido progressivamente).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SDR
  CLOSER
}

enum Origem {
  PAGO
  ORGANICO
}

enum ReuniaoStatus {
  PENDENTE
  FEITA
  NO_SHOW
}

enum Resultado {
  EM_ANDAMENTO
  GANHO
  PERDIDO
}

// Cadastro de membros da equipe (SDRs e Closers).
model TeamMember {
  id        String   @id @default(cuid())
  nome      String
  role      Role
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  leadsComoSdr    Lead[] @relation("SdrLeads")
  leadsComoCloser Lead[] @relation("CloserLeads")
}

// Cadastro de criativos (peças de anúncio — nível de Anúncio no Meta Ads).
model Criativo {
  id        String   @id @default(cuid())
  nome      String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  // Hierarquia de campanha (preenchida manualmente ou pelo auto-sync do Meta).
  campanha  String?
  conjunto  String?

  // IDs do Meta Ads, usados pelo auto-sync (webhook de Lead Ads) pra casar
  // o lead recebido com o Criativo certo, e auto-criar se for novo.
  metaAdId       String? @unique
  metaAdsetId    String?
  metaCampaignId String?

  leads          Lead[]
  investimentos  CriativoMensal[]
}

// Investimento mensal por criativo + marcação de vencedor.
model CriativoMensal {
  id            String   @id @default(cuid())
  criativoId    String
  criativo      Criativo @relation(fields: [criativoId], references: [id], onDelete: Cascade)
  mes           String   // formato "YYYY-MM"
  investimento  Float
  vencedor      Boolean  @default(false)

  @@unique([criativoId, mes])
}

// Lista fixa de motivos de não-fechamento (reunião feita, proposta apresentada, mas não fechou).
model MotivoNaoFechamento {
  id    String @id @default(cuid())
  nome  String @unique
  ativo Boolean @default(true)

  leads Lead[]
}

// Entidade central: um lead, atualizado progressivamente ao longo do funil.
model Lead {
  id        String   @id @default(cuid())
  data      DateTime // data de entrada do lead
  origem    Origem

  // ID do leadgen no Meta (leadgen_id), usado pelo webhook e pelo backfill
  // histórico pra evitar criar o mesmo lead duas vezes.
  metaLeadId String? @unique

  // Respostas que o lead preencheu no formulário nativo do Meta (nome,
  // telefone, e-mail etc.), guardadas como vieram (chave/valor) pra exibir
  // na tela de detalhe. Só existe pra leads vindos do Meta (webhook/sync).
  dadosFormulario Json?

  // Dados de contato do lead, preenchidos manualmente (principalmente para
  // leads cadastrados na mão, que não têm dadosFormulario do Meta).
  nome        String?
  telefone    String?
  email       String?
  instagram   String?
  observacoes String?

  criativoId String?
  criativo   Criativo? @relation(fields: [criativoId], references: [id])

  sdrId String?
  sdr   TeamMember? @relation("SdrLeads", fields: [sdrId], references: [id])

  qualificado Boolean?
  agendou     Boolean?

  reuniaoStatus ReuniaoStatus @default(PENDENTE)

  closerId String?
  closer   TeamMember? @relation("CloserLeads", fields: [closerId], references: [id])

  motivoNaoFechamentoId String?
  motivoNaoFechamento   MotivoNaoFechamento? @relation(fields: [motivoNaoFechamentoId], references: [id])

  resultado Resultado @default(EM_ANDAMENTO)
  receita   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([data])
  @@index([sdrId])
  @@index([closerId])
}

// Investimento diário em mídia (independe de criativo específico).
model InvestimentoDiario {
  id     String   @id @default(cuid())
  data   DateTime @unique
  valor  Float
}

// Métricas mensais de operação (para NPS, LTV, Payback CAC, Churn, NRR).
model MetricaMensal {
  id             String @id @default(cuid())
  mes            String @unique // "YYYY-MM"

  custoComercial Float // custo total da operação comercial no mês (para CAC)

  logosInicio    Int
  logosPerdidos  Int

  mrrInicio      Float
  mrrPerdido     Float
  mrrExpansao    Float

  clientesAtivos Int

  promotores  Int
  neutros     Int
  detratores  Int

  faturamento Float
}

// Metas do mês.
model MetaMensal {
  id                    String @id @default(cuid())
  mes                   String @unique // "YYYY-MM"
  metaLeads             Int
  metaFechamentos       Int
  metaReceita           Float
  metaCplQualificado    Float
}

// Usuários com acesso ao painel (login).
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String
  isAdmin      Boolean  @default(false)
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())

  // Última vez que o usuário abriu/marcou as notificações como vistas — usado
  // pelo sino do painel pra contar quantos leads novos entraram desde então.
  notificacoesVistasEm DateTime?
}

// Configuração da integração com o Meta (Conversions API), editável pelo Admin
// sem precisar redeploy. Singleton: sempre a linha de id "meta". Se vazio, o
// envio de eventos cai no fallback das variáveis de ambiente (ou é no-op).
model IntegracaoMeta {
  id           String   @id @default("meta")
  datasetId    String? // Pixel / Dataset ID do Events Manager
  capiToken    String? // token da Conversions API desse Dataset
  sourceName   String? // nome da origem que aparece no Events Manager
  atualizadoEm DateTime @updatedAt
}

// Configuração da integração com o WhatsApp (uazapi), editável pelo Admin sem
// redeploy. Singleton: sempre a linha de id "whatsapp". Se vazio/inativo, o
// envio de notificação por WhatsApp é no-op. O "destino" é pra onde a mensagem
// vai: um número (55DDDNUMERO) ou o ID de um grupo (…@g.us).
model IntegracaoWhatsapp {
  id           String   @id @default("whatsapp")
  baseUrl      String? // ex: https://controlmidia.uazapi.com
  token        String? // token da instância no uazapi
  destino      String? // número (55…) ou ID do grupo (…@g.us)
  destinoNome  String? // nome do destino (informativo, ex: "Comercial Control")
  ativo        Boolean  @default(true)
  atualizadoEm DateTime @updatedAt
}

// Inscrição de Web Push (PWA) de um dispositivo, pra enviar notificação de
// lead novo no celular mesmo com o app fechado. Uma linha por navegador/app
// que ativou as notificações.
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  username  String? // quem ativou (informativo); a notificação vai pra todos
  createdAt DateTime @default(now())
}
